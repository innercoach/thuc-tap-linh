# ----------------------------------------------------------------------
# Database / App Environment Example
# ----------------------------------------------------------------------
# Đây là file .env mẫu dùng để cấu hình app, database và session.
# Người dùng có thể copy nội dung file này sang .env rồi chỉnh giá trị
# phù hợp với máy local hoặc môi trường triển khai.

APP_NAME="Landing Page MVC"
APP_URL="http://localhost:8080"
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=landing_page_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

SESSION_NAME=landing_page_session
SESSION_LIFETIME=0
SESSION_IDLE_TIMEOUT=1800
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax
